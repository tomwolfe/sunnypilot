import os

Import('env', 'arch', 'common', 'messaging', 'visionipc', 'replay_lib', 'cereal')

# Base libraries needed (removing QT dependencies)
base_libs = [common, messaging, cereal, visionipc, 'avutil', 'avcodec', 'avformat', 'bz2', 'zstd', 'curl', 'yuv', 'usb-1.0']

# Create environment for Raylib Cabana
cabana_env = env.Clone()

# Add Raylib libraries
if arch == "Darwin":
    cabana_env.Append(LIBS=['raylib', 'm', 'pthread', 'dl', 'c'])
    # On macOS, we might need to link additional frameworks for Raylib
    cabana_env.Append(FRAMEWORKS=['CoreVideo', 'OpenGL', 'IOSurface'])
else:
    cabana_env.Append(LIBS=['raylib', 'm', 'pthread', 'dl', 'rt', 'c', 'GL', 'X11', 'Xrandr', 'Xi', 'Xcursor', 'Xinerama', 'Xss'])

# Include paths for dependencies
opendbc_path = '-DOPENDBC_FILE_PATH=\'"%s"\'' % (cabana_env.Dir("../../opendbc/dbc").abspath)
cabana_env['CXXFLAGS'] += [opendbc_path]

# Source files for the Raylib-based Cabana
cabana_src = [
    # Core raylib UI components
    'raylib_mainwin.cc',
    'raylib_centerwidget.cc',
    'raylib_messageswidget.cc',
    'raylib_chartswidget.cc',
    'raylib_videowidget.cc',
    'raylib_signalview.cc',
    'raylib_detailwidget.cc',
    'raylib_binaryview.cc',
    'raylib_cameraview.cc',
    'raylib_findsignal.cc',
    'raylib_findsimilarbits.cc',
    'raylib_routeinfo.cc',
    'raylib_settings.cc',
    'raylib_settings_dialog.cc',

    # Stream implementations
    'streams/abstractstream.cc',
    'streams/pandastream.cc',
    'streams/socketcanstream.cc',
    'streams/livestream.cc',
    'streams/routes.cc',

    # DBC management
    'dbc/dbc.cc',
    'dbc/dbcfile.cc',
    'dbc/dbcmanager.cc',

    # Utilities
    'utils/export.cc',
    'utils/util.cc',
    'utils/elidedlabel.cc',

]

# Build the Cabana library
cabana_lib = cabana_env.Library("cabana_lib", cabana_src, LIBS=base_libs + cabana_env['LIBS'])

# Build the Cabana executable
cabana_env.Program('cabana', ['cabana.cc', cabana_lib], LIBS=base_libs + cabana_env['LIBS'])

if GetOption('extras'):
  cabana_env.Program('tests/test_cabana', ['tests/test_runner.cc', 'tests/test_cabana.cc', cabana_lib], LIBS=base_libs + cabana_env['LIBS'])

output_json_file = 'tools/cabana/dbc/car_fingerprint_to_dbc.json'
generate_dbc = cabana_env.Command('#' + output_json_file,
                                  ['dbc/generate_dbc_json.py'],
                                  "python3 tools/cabana/dbc/generate_dbc_json.py --out " + output_json_file)
cabana_env.Depends(generate_dbc, ["#common", '#opendbc_repo', "#cereal", "#msgq_repo"])
