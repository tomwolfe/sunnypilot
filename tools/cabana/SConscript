Import('env', 'arch', 'common', 'messaging', 'visionipc', 'replay_lib', 'cereal')

# Base libraries needed (removing QT dependencies)
base_libs = [common, messaging, cereal, visionipc, 'avutil', 'avcodec', 'avformat', 'bz2', 'zstd', 'curl', 'yuv', 'usb-1.0']

# Create environment for Raylib Cabana
cabana_raylib_env = env.Clone()

# Add Raylib libraries
if arch == "Darwin":
    cabana_raylib_env.Append(LIBS=['raylib', 'm', 'pthread', 'dl', 'rt', 'c'])
    # On macOS, we might need to link additional frameworks for Raylib
    cabana_raylib_env.Append(FRAMEWORKS=['CoreVideo', 'OpenGL', 'IOSurface'])
else:
    cabana_raylib_env.Append(LIBS=['raylib', 'm', 'pthread', 'dl', 'rt', 'c', 'GL', 'X11', 'Xrandr', 'Xi', 'Xcursor', 'Xinerama', 'Xss'])

# Note: Some Qt dependencies remain for backend functionality (streams, data handling)
# Full Qt removal would require refactoring core data structures, which is a larger project

# Include paths for dependencies
opendbc_path = '-DOPENDBC_FILE_PATH=\'"%s"\'' % (cabana_raylib_env.Dir("../../opendbc/dbc").abspath)
cabana_raylib_env['CXXFLAGS'] += [opendbc_path]

# Source files for the Raylib-based Cabana
raylib_cabana_src = [
    # Main application files
    'raylib_cabana.cc',
    'raylib_mainwin.cc',  # Use Raylib implementation of main window

    # UI components
    'raylib_messageswidget.cc',
    'raylib_videowidget.cc',
    'raylib_chartswidget.cc',

    # Core functionality files (non-UI)
    'raylib_socketcanstream.cc',  # Use Raylib implementation instead of streams/socketcanstream.cc
    'streams/pandastream.cc',  # Core functionality without Qt dependencies
    'raylib_devicestream.cc',  # Use Raylib implementation instead of streams/devicestream.cc
    'streams/livestream.cc',  # Core functionality without Qt dependencies
    'streams/abstractstream.cc',  # Core functionality without Qt dependencies
    'raylib_replaystream.cc',  # Use Raylib implementation instead of streams/replaystream.cc
    'streams/routes.cc',
    'dbc/dbc.cc',
    'dbc/dbcfile.cc',
    'dbc/dbcmanager.cc',
    'utils/export.cc',

    # Additional components
    'raylib_settings.cc',  # Raylib implementation
    'raylib_binaryview.cc',  # Raylib implementation
    'raylib_detailwidget.cc',  # Raylib implementation
    'panda.cc',

    # Raylib UI components
    'raylib_cameraview.cc',
    'raylib_centerwidget.cc',

    # Raylib POC components that may have useful code
    'raylib_poc/cabana_ui_components.cc',
    'raylib_poc/cabana_panels.cc'
]

# Build the Raylib Cabana executable
cabana_raylib = cabana_raylib_env.Program('cabana', raylib_cabana_src,
                                         LIBS=base_libs + cabana_raylib_env['LIBS'])

# Build assets (convert from QT resources to Raylib-compatible format if needed)
# For now, we'll skip the assets build since it's QT-specific
# assets = "assets/assets.cc"
# assets_src = "assets/assets.qrc"
# cabana_raylib_env.Command(assets, assets_src, f"rcc $SOURCES -o $TARGET")
# cabana_raylib_env.Depends(assets, Glob('/assets/*', exclude=[assets, assets_src, "assets/assets.o"]))

if GetOption('extras'):
  cabana_raylib_env.Program('tests/test_cabana', ['tests/test_runner.cc', 'tests/test_cabana.cc', cabana_raylib], LIBS=base_libs + cabana_raylib_env['LIBS'])

output_json_file = 'tools/cabana/dbc/car_fingerprint_to_dbc.json'
generate_dbc = cabana_raylib_env.Command('#' + output_json_file,
                                  ['dbc/generate_dbc_json.py'],
                                  "python3 tools/cabana/dbc/generate_dbc_json.py --out " + output_json_file)
cabana_raylib_env.Depends(generate_dbc, ["#common", '#opendbc_repo', "#cereal", "#msgq_repo"])

Return('cabana_raylib')